# Redflix Streaming — Variáveis de Ambiente
# Copie para .env e preencha os valores. Nunca commite .env no repositório.

# ═══════════════════════════════════════════════════════════
# OBRIGATÓRIAS
# ═══════════════════════════════════════════════════════════

# Supabase — projeto atual (Dashboard → Settings → API)
# Project ref: encontre em https://supabase.com/dashboard → Settings → API
# Este app é Vite: use VITE_* (não NEXT_PUBLIC_*).
# APK / `vite build`: estes valores são embutidos no JS — use sempre URL e anon key reais (Dashboard → Settings → API).
# Pode usar ficheiro `.env.production` (gitignored) só para releases; o Vite carrega em modo production.
VITE_SUPABASE_URL=https://SEU-PROJETO-REF.supabase.co

# Só se a API não for *.supabase.co (self-hosted / domínio próprio): VITE_ALLOW_CUSTOM_SUPABASE_URL=1

# Opcional: URL base de outro projeto Supabase só para imagens WebP em Storage (banners).
# Se vazio, usa VITE_SUPABASE_URL para .../storage/v1/object/public/posters/webp/{tmdbId}.webp
# VITE_SUPABASE_IMAGES_URL=https://seu-projeto.supabase.co

# Chave anon (JWT "anon public" ou publishable do dashboard) — segura no cliente
VITE_SUPABASE_ANON_KEY=

# Service role — SOMENTE scripts Node (scripts/supabase-env.mjs).
# Variável aceita: SUPABASE_SERVICE_ROLE_KEY ou VITE_SUPABASE_SERVICE_ROLE_KEY
# Nunca no bundle do app / APK. Dashboard → API → service_role (secret).
# SUPABASE_SERVICE_ROLE_KEY=

# IA server-side (OpenAI ou OpenAI Compatible)
# Use apenas em código Node/server. Não use prefixo VITE_ para não ir para o bundle.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini-code
# Opcional: force o formato da API. Default = `responses` para OpenAI oficial, `chat` para base URL customizada.
# OPENAI_API_MODE=responses

# ═══════════════════════════════════════════════════════════
# OPCIONAIS
# ═══════════════════════════════════════════════════════════

# TMDB — API Key (para busca de filmes/séries)
VITE_TMDB_API_KEY=

# TMDB — Read Access Token (alternativa à API Key)
VITE_TMDB_READ_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# SENTRY — Monitoramento de erros em produção (opcional, gratuito até 5k/mês)
# Crie projeto em https://sentry.io → copie o DSN aqui para ativar
# Sem DSN = sem coleta, sem overhead no app
# ─────────────────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=

# Versão humana para agrupar eventos no Sentry (default no build: version do package.json)
# VITE_APP_VERSION=1.0.0
# Opcional: dist/build id no Sentry
# VITE_SENTRY_DIST=ci-123

# E2E: só em `vite build --mode e2e` (ver `.env.e2e`). Não use em produção.
# VITE_E2E=1

# TMDB — Vários tokens Bearer (recomendado: 3 contas/APIs)
# Separe por vírgula SEM espaços entre tokens (ou com trim automático).
# Cada requisição ao TMDB usa o próximo token (round-robin); em 429 o retry já troca de token.
# Ex.: VITE_TMDB_READ_TOKENS=eyJ...,eyJ...,eyJ...
VITE_TMDB_READ_TOKENS=

# API de esportes (futebol, etc.)
VITE_SPORTS_API_TOKEN=

# URL da REDX API ESPORTE
VITE_SPORTS_API_URL=https://futebol-brasil-api-vercel-ok.vercel.app

# TheSportsDB — API Key (free tier: "3" | paga: sua chave em thesportsdb.com/api)
VITE_SPORTS_DB_KEY=3

# Bypass de autenticação admin (apenas desenvolvimento — NUNCA true em produção)
# VITE_ADMIN_BYPASS=true

# Fallback emergencial da senha admin quando a Edge Function ainda não foi publicada.
# Use apenas para destravar o ambiente local e remova após publicar verify-admin-password.
VITE_ADMIN_PASSWORD_FALLBACK=

# ═══════════════════════════════════════════════════════════
# Edge Function verify-admin-password (Supabase — painel admin em produção)
# ═══════════════════════════════════════════════════════════
# 1. Instale o CLI: https://supabase.com/docs/guides/cli
# 2. supabase login && supabase link --project-ref SEU_REF
# 3. Defina o secret (nunca commite a senha):
#    supabase secrets set ADMIN_PASSWORD="senha_forte_do_painel"
# 4. Deploy da função incluída em supabase/functions/verify-admin-password/:
#    npm run supabase:deploy-admin-fn
# O app chama essa função em signInAsAdmin; sem secret a API responde ok:false com mensagem clara.

# Login fake para testes locais (sem Supabase auth). Use só em dev.
# VITE_FAKE_LOGIN=true
# VITE_FAKE_LOGIN_EMAIL=teste@redflix.local

# APK/TV de teste: no build de produção aceita código 000000. NUNCA em build de loja.
# VITE_TV_TEST_LOGIN=true
# (Sem VITE_BUILD_CHANNEL, o Vite assume canal "testing" para o 000000 funcionar no APK.)
