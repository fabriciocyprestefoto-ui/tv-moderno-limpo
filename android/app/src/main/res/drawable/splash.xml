<?xml version="1.0" encoding="utf-8"?>
<!-- Splash screen - Logo REDX sobre gradiente roxo (estilo login) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fundo gradiente roxo (como página de login) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#581C87"
                android:centerColor="#3B0764"
                android:endColor="#1E0A3C"
                android:type="linear" />
        </shape>
    </item>
    <!-- Logo REDX centralizado -->
    <item android:gravity="center">
        <bitmap
            android:src="@drawable/logored"
            android:gravity="center" />
    </item>
</layer-list>
