{
  "name": "redflix-tv-moderno",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:open": "vite --open",
    "build": "vite build",
    "build:testing": "vite build --mode testing",
    "preview": "vite preview",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "generate:launcher": "node scripts/generate_launcher_icons.mjs",
    "build:android": "vite build && npx cap sync android",
    "build:android:testing": "vite build --mode testing && npx cap sync android",
    "build:android:store": "cross-env VITE_APP_TARGET=tv VITE_BUILD_CHANNEL=production VITE_STORE_SAFE_BUILD=true VITE_ENABLE_ADULT_CONTENT=false VITE_TV_TEST_LOGIN=false vite build && npx cap sync android",
    "build:android:full": "cross-env VITE_APP_TARGET=tv VITE_BUILD_CHANNEL=testing VITE_STORE_SAFE_BUILD=false VITE_ENABLE_ADULT_CONTENT=true vite build --mode testing && npx cap sync android",
    "check:release-signature": "node scripts/check-release-signature.mjs",
    "build:apk": "npm run check:release-signature && npm run generate:launcher && cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build && npx cap sync android && cd android && .\\gradlew.bat assembleRelease && node ../scripts/copy-apk.mjs release",
    "build:apk:store": "npm run check:release-signature && npm run generate:launcher && cross-env NODE_OPTIONS=--max-old-space-size=4096 VITE_APP_TARGET=tv VITE_BUILD_CHANNEL=production VITE_STORE_SAFE_BUILD=true VITE_ENABLE_ADULT_CONTENT=false VITE_TV_TEST_LOGIN=false vite build && npx cap sync android && cd android && .\\gradlew.bat assembleRelease && node ../scripts/copy-apk.mjs release",
    "build:apk:debug": "npm run generate:launcher && cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build && npx cap sync android && cd android && .\\gradlew.bat assembleDebug && node ../scripts/copy-apk.mjs debug",
    "build:apk:debug:full": "npm run generate:launcher && cross-env NODE_OPTIONS=--max-old-space-size=4096 VITE_APP_TARGET=tv VITE_BUILD_CHANNEL=testing VITE_STORE_SAFE_BUILD=false VITE_ENABLE_ADULT_CONTENT=true vite build --mode testing && npx cap sync android && cd android && .\\gradlew.bat assembleDebug && node ../scripts/copy-apk.mjs debug",
    "create:keystore": "scripts\\create_keystore.bat",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "preview:e2e": "vite preview --mode e2e --port 4173 --strictPort --host 127.0.0.1",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:node": "vitest run --config vitest.config.ts --project node",
    "test:jsdom": "vitest run --config vitest.config.ts --project jsdom",
    "cy:run:ci": "cypress run --config baseUrl=http://127.0.0.1:4173 --reporter mocha-junit-reporter --reporter-options mochaFile=cypress/results/e2e-junit.xml,toConsole=false",
    "e2e": "start-server-and-test dev http://127.0.0.1:5173 cy:run",
    "e2e:ci": "node scripts/run-e2e-ci.mjs",
    "testsprite": "npx playwright test --config playwright.config.ts",
    "testsprite:ui": "npx playwright test --config playwright.config.ts --headed",
    "audit:vod": "node scripts/audit-vod-streams.mjs",
    "sync:images": "node scripts/sync-tmdb-images-to-supabase.mjs",
    "sync:images:dry": "node scripts/sync-tmdb-images-to-supabase.mjs --dry-run --limit=20",
    "supabase:sync-stream-urls": "node scripts/sync-stream-urls-from-columns.mjs",
    "supabase:sync-stream-urls:apply": "node scripts/sync-stream-urls-from-columns.mjs --apply",
    "desktop": "electron .",
    "build:desktop": "npm run build && electron-builder --win portable",
    "supabase:deploy-tmdb-fn": "supabase functions deploy tmdb-proxy",
    "supabase:deploy-admin-fn": "supabase functions deploy verify-admin-password",
    "compress:kids-intro": "node scripts/compress-kids-intro.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@emotion/is-prop-valid": "^1.4.0",
    "@sentry/react": "^10.46.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-virtual": "^3.13.23",
    "events": "^3.3.0",
    "framer-motion": "^12.34.0",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.563.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.7.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-legacy": "^6.1.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.24",
    "cross-env": "^10.1.0",
    "cypress": "^15.12.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "ffmpeg-static": "^5.2.0",
    "jsdom": "^29.0.1",
    "mocha-junit-reporter": "^2.2.1",
    "msw": "^2.12.14",
    "pg": "^8.19.0",
    "prettier": "3.8.1",
    "sharp": "^0.34.5",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^4.1.2"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.redflix.desktop",
    "productName": "Redflix",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
